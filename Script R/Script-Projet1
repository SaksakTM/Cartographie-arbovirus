  pred_i     <- predict.gbm(brt_models[[i]], data_env, n_best, "response", FALSE)
  
  P    <- sum(responses == 1) #nombre (150) de présences
  A    <- sum(responses == 0) #nb de pseudo-absences (comme c'est un ratio 1:1, 150 aussi)
  prev <- P / (P + A) #prévalence (proportion de présences ds le jeu de données)
  x    <- (P / A) * ((1 - prev) / prev) #(facteur de correction du ratio présences/pseudo-absences, mais ici, avec le ratio 1:1, il est égal à 1)
  SI_ppc_best <- 0
  
  for (threshold in seq(0, 1, 0.01)) {
    TP         <- length(which((responses == 1) & (pred_i >= threshold)))
    FN         <- length(which((responses == 1) & (pred_i <  threshold)))
    FP_pa      <- length(which((responses == 0) & (pred_i >= threshold)))
    SI_ppc_tmp <- (2 * TP) / ((2 * TP) + (x * FP_pa) + FN)
    tmp[which(tmp[, "threshold"] == threshold), "SIppc"] <- SI_ppc_tmp
    if (SI_ppc_best < SI_ppc_tmp) {
      SI_ppc_best         <- SI_ppc_tmp
      optimised_threshold <- threshold
    }
  }
  SI_ppcs[i]    <- SI_ppc_best
  thresholds[i] <- optimised_threshold
}

cat("SIppc moyen =", round(mean(SI_ppcs), 2),
    "| Intervalle SIppc = [", round(min(SI_ppcs), 2), ",", round(max(SI_ppcs), 2), "]\n")
cat("Seuil optimal moyen =", round(mean(thresholds), 2), "\n")

perf_summary <- data.frame(AUC = AUCs[,1], SIppc = SI_ppcs, threshold = thresholds)
