    "| Intervalle AUC = [", round(min(AUCs[,1]), 2), ",", round(max(AUCs[,1]), 2), "]\n")

brt_models <- readRDS(file.path(output_dir, "BRT_model_replicates.rds"))

SI_ppcs    <- rep(NA, length(brt_models))
thresholds <- rep(NA, length(brt_models))

for (i in seq_along(brt_models)) {
  tmp <- matrix(nrow = 101, ncol = 2, dimnames = list(NULL, c("threshold", "SIppc")))
  tmp[, "threshold"] <- seq(0, 1, 0.01)
  
  df_i       <- brt_models[[i]]$gbm.call$dataframe
