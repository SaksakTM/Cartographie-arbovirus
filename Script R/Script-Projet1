fmt_stat <- function(vals, label) {
  m  <- round(mean(vals), 3)
  s  <- round(sd(vals),   3)
  lo <- round(t.test(vals)$conf.int[1], 3)
  hi <- round(t.test(vals)$conf.int[2], 3)
  mn <- round(min(vals), 3)
  mx <- round(max(vals), 3)
  cat(sprintf("  %-22s  moy = %s  (IC95%% : [%s, %s])  sd = %s  min = %s  max = %s\n",
              label, m, lo, hi, s, mn, mx))
}

