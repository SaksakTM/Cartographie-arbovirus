# ============================================================
# ETAPE 7 : Entraînement des modèles BRT (réplicats)
# ============================================================

gbm.x              <- envVariableNames          # variables explicatives (colonnes du data frame)
gbm.y              <- "response"                # var. réponse (présence=1 / pseudo-absence=0)
offset             <- NULL
tree.complexity    <- 5                         # profondeur max des arbres ("tc") — nb de nœuds
learning.rate      <- 0.005                     # contribution de chaque arbre au modèle ("lr")
bag.fraction       <- 0.80                      # proportion d'observations utilisées/arbre
var.monotone       <- rep(0, length(gbm.x))     # 0 => pas de contrainte de monotonie sur les variables
n.folds            <- 5                         # nombre de blocs spatiaux pour la cross-validation
# pas d'intérêt à définir une variable comme "prev.stratify" car pas d'effet ds notre cas : blocs sont déjà définis par cv_spatial (via fold.vector)
family             <- "bernoulli"               # distribution statistique (réponse binaire 0/1)
step.size          <- 5                         # intervalle auquel la déviance prédictive est calculée
max.trees          <- 10000                     # nb maximum d'arbres que l'algorithme peut construire
tolerance.method   <- "auto"                    # méthode d'arrêt automatique de l'algorithme
tolerance          <- 0.001                     # seuil : arrêt quand réduction de déviance < tolérance (Elith et al. (2008))
plot.main          <- TRUE                      # affichage de la courbe de déviance résiduelle
plot.folds         <- FALSE                     # ne pas afficher les blocs de cross-validation
verbose            <- TRUE                      # affichage des messages pdt l'entraînement
silent             <- FALSE                     # ne pas activer le mode silencieux
keep.fold.models   <- FALSE                     # ne pas conserver les modèles par fold
keep.fold.vector   <- FALSE                     # ne pas conserver les identifiants de fold
keep.fold.fit      <- FALSE                     # ne pas conserver les prédictions par fold

brt_models  <- list()
predictions <- list()
AUCs        <- matrix(nrow = number_of_replicates, ncol = 1, dimnames = list(NULL, "AUC"))

for (i in 1:number_of_replicates) {
  cat("\n=== Réplicat", i, "/", number_of_replicates, "===\n")
  data_i <- dataframes[[i]]
  
  spdf <- SpatialPointsDataFrame(
    data_i[c("longitude", "latitude")],
    data_i[, c("response", envVariableNames)],
    proj4string = crs(template)
  )
  
  myblocks    <- cv_spatial(spdf, column = "response", k = n.folds,
                            size = theRanges[1], selection = "random")
  fold.vector <- myblocks$folds_ids
  
  n.trees      <- 10  # nb initial d'arbres (réinitialisé à chaque réplicat) ; cf'est gbm.step() qui détermine après
                      # best.trees (nb optimal d'arbres minimisant la déviance, en cross-validation spatiale)
  site.weights <- rep(1, dim(data_i)[1])
  
  brt_models[[i]] <- gbm.step(
    data_i, gbm.x, gbm.y, offset, fold.vector, tree.complexity,
    learning.rate, bag.fraction, site.weights, var.monotone, n.folds,
    TRUE, family, n.trees, step.size, max.trees,
    tolerance.method, tolerance, plot.main, plot.folds, verbose, silent,
    keep.fold.models, keep.fold.vector, keep.fold.fit
  )
  
  AUCs[i, "AUC"] <- brt_models[[i]]$cv.statistics$discrimination.mean

  # Prédiction de l'adéquation écologique pour chaque pixel du raster EU
  df_pred   <- as.data.frame(stack(envVariables))          # valeurs env. de chaque pixel en data frame
  df_pred   <- df_pred[which(!is.na(rowMeans(df_pred))), ] # suppression des lignes avec NA
  n_best    <- brt_models[[i]]$gbm.call$best.trees          # nb optimal d'arbres pour ce réplicat
  pred_vals <- predict.gbm(brt_models[[i]], df_pred, n_best, "response", FALSE)

  buf <- envVariables[[1]]        # raster vide (même emprise/résolution que les rasters env.)
  buf[!is.na(buf[])] <- pred_vals # remplissage avec les valeurs prédites, pixel par pixel
  predictions[[i]] <- buf
}

