#Bloc permettant de sauvegarder extérieurement les figures d'intéret en PDF (vectorisé), SVG (vectorisé) et PNG (300 dpi)
save_formats <- function(base_name, width, height, plot_fn) {
  for (fmt in c("pdf", "svg", "png")) {
    fpath <- file.path(output_dir, paste0(base_name, ".", fmt))
    if      (fmt == "pdf") pdf(fpath, width = width, height = height)
    else if (fmt == "svg") svg(fpath, width = width, height = height)
    else                   png(fpath, width = width, height = height, units = "in", res = 300)
    plot_fn()
    dev.off()
  }
}


